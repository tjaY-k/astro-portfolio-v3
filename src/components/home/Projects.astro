---
import { getCollection } from 'astro:content';
import { ArrowIcon } from '../ui/icons';

const allProjects = await getCollection('projects');

const projects = allProjects
  .filter((p) => p.data.featured === true)
  .sort((a, b) => b.data.year - a.data.year);

const projectsWithContent = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await project.render();
    return { project, Content };
  }),
);
---

<section class='py-20 relative' id='projects'>
  <div class='container-fluid'>
    <div>
      <h2 class='text-4xl font-semibold text-foreground mb-3 text-center first-letter-color'>
        Featured Projects
      </h2>
      <p class='text-center text-muted-foreground text-lg mb-3'>
        A selection of my recent work
      </p>
      <div class='h-1 w-20 bg-linear-to-r from-primary to-secondary rounded-full mx-auto mb-16'></div>
    </div>

    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 auto-rows-[300px]'>
      {
        projectsWithContent.map(({ project }, index) => {
          const getGridClass = (i: number) => {
            const patterns = ['md:col-span-2 md:row-span-2', 'md:col-span-1 md:row-span-1', 'md:col-span-1 md:row-span-1', 'md:col-span-1 md:row-span-1', 'md:col-span-2 md:row-span-1', 'md:col-span-1 md:row-span-1', 'md:col-span-2 md:row-span-2', 'md:col-span-1 md:row-span-1'];
            return patterns[i % patterns.length];
          };

          return (
            <article
              class={`group relative overflow-hidden rounded-xl border border-border/50 bg-card hover:border-primary/30 transition-all duration-500 hover:shadow-xl hover:shadow-primary/5 cursor-pointer animate-blur-fade ${getGridClass(index)}`}
              style={`animation-delay: ${index * 0.1}s`}
              data-project-id={project.id}
            >
              {project.data.video ? (
                <div class='absolute inset-0 overflow-hidden'>
                  <video
                    src={project.data.video}
                    poster={project.data.cover_image || project.data.image}
                    class='w-full h-full object-cover group-hover:scale-110 transition-transform duration-700'
                    muted
                    loop
                    playsinline
                    preload='none'
                  ></video>
                  <div class='absolute inset-0 bg-linear-to-t from-black/90 via-black/70 to-black/20' />
                </div>
              ) : project.data.cover_image ? (
                <div class='absolute inset-0 overflow-hidden'>
                  <img
                    src={project.data.cover_image}
                    alt={project.data.title}
                    class='w-full h-full object-cover group-hover:scale-110 transition-transform duration-700'
                    loading='lazy'
                  />
                  <div class='absolute inset-0 bg-linear-to-t from-black/90 via-black/70 to-black/20' />
                </div>
              ) : (
                <div class='absolute inset-0 overflow-hidden bg-linear-to-br from-primary/20 to-secondary/20' />
              )}

              <div class='relative h-full flex flex-col justify-end p-6 space-y-4'>
                <h3 class='text-2xl font-bold text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)] group-hover:text-primary-foreground transition-colors first-letter-color'>
                  {project.data.title}
                </h3>

                <div class='flex flex-wrap gap-2'>
                  {project.data.tech.slice(0, 3).map((tech) => (
                    <span class='px-3 py-1 bg-white/20 text-white rounded-full text-xs font-medium border border-white/30 backdrop-blur-sm'>
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class='text-center mt-10'>
      <a href='/projects' class='inline-flex items-center gap-2 px-5 text-sm py-2.5 border border-primary text-primary rounded-md font-medium hover:bg-primary hover:text-background transition-all hover:scale-105'>
        View All Projects
        <ArrowIcon class='w-4 h-4' />
      </a>
    </div>
  </div>
</section>

<!-- Project Modal -->
<dialog id='project-modal' class='backdrop:bg-background/90 backdrop:backdrop-blur-md bg-card border border-border rounded-3xl max-w-4xl w-full p-0 shadow-2xl m-auto max-h-[95vh] overflow-hidden'>
  <div class='relative max-h-[95vh] overflow-y-auto' id='modal-content'></div>
</dialog>

<script define:vars={{ projectsData: projectsWithContent.map(({ project }) => ({
  id: project.id,
  title: project.data.title,
  description: project.data.description,
  tech: project.data.tech,
  image: project.data.cover_image || project.data.image,
  video: project.data.video,
  external_link: project.data.external_link,
  year: project.data.year,
})) }}>
  function initProjectModals() {
    const cards = document.querySelectorAll('[data-project-id]');
    const modal = document.getElementById('project-modal');
    const modalContent = document.getElementById('modal-content');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-project-id');
        const project = projectsData.find(p => p.id === id);
        if (!project) return;

        const html = `
          <div class="p-8 md:p-10">
            ${project.video 
              ? `<video src="${project.video}" controls autoplay class="w-full rounded-2xl mb-8 shadow-xl"></video>` 
              : `<img src="${project.image}" class="w-full rounded-2xl mb-8 shadow-xl">`
            }
            
            <h2 class="text-4xl font-bold mb-2 text-foreground">${project.title}</h2>
            <p class="text-muted-foreground text-lg leading-relaxed mb-8">${project.description}</p>
            
            <div class="flex flex-wrap gap-3 mb-10">
              ${project.tech.map(t => `<span class="px-5 py-2 bg-secondary text-sm rounded-full font-medium">${t}</span>`).join('')}
            </div>

            ${project.external_link 
              ? `<a href="${project.external_link}" target="_blank" class="inline-flex items-center gap-3 bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-2xl font-semibold text-lg transition-all">Visit Project <span class="text-xl">→</span></a>` 
              : ''}
            
            <button onclick="document.getElementById('project-modal').close()" 
                    class="absolute top-6 right-6 text-4xl text-muted-foreground hover:text-foreground transition-colors">×</button>
          </div>
        `;

        modalContent.innerHTML = html;
        modal.showModal();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProjectModals);
</script>