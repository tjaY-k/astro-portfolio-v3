---
import { ArticleCard, ShareModal } from '@/components/shared';
import AuthorSidebar from '@/components/AuthorSidebar.astro';
import SocialShare from '@/components/SocialShare.astro';
import SponsorsSidebar from '@/components/SponsorsSidebar.astro';
import NewsletterModal from '@/components/shared/NewsletterModal.astro';
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  author: string;
  dateCreated: Date;
  dateModified?: Date;
  tags?: string[];
  coverImage?: string;
  ogImage?: string;
  series?: string;
  readingTime: number;
  sponsors?: CollectionEntry<'sponsors'>[];
  relatedBlogs?: CollectionEntry<'blog'>[];
  canonical?: string;
}

const {
  title,
  description,
  author,
  dateCreated,
  dateModified,
  tags = [],
  coverImage,
  ogImage,
  series,
  readingTime,
  sponsors = [],
  relatedBlogs = [],
  canonical,
} = Astro.props;

const hasSponsors = sponsors.length > 0;

// Format dates
const formattedDate = dateCreated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedModifiedDate = dateModified?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isUpdated = dateModified && dateModified.getTime() !== dateCreated.getTime();

const seriesSlug = series ? series.toLowerCase().replace(/\s+/g, '-') : null;

const pageTitle = `${title} | Lewis Kori`;
const publishedTime = dateCreated.toISOString();
const modifiedTime = dateModified?.toISOString();

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://lewiskori.com';
const slug = Astro.params.slug as string;

// Fix ogImage: ensure it's always a string URL, never an ImageMetadata object
const ogImageUrl = typeof ogImage === 'string' ? ogImage : `${siteUrl}/opengraph.png`;

const breadcrumbs = [
  { name: 'Home', item: siteUrl },
  { name: 'Writing', item: `${siteUrl}/blog` },
  { name: title, item: `${siteUrl}/blog/${slug}` },
];
---

<Layout
  title={pageTitle}
  description={description}
  ogTitle={title}
  ogDescription={description}
  image={ogImageUrl}
  author={author}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  type='article'
  canonical={canonical}
  breadcrumbs={breadcrumbs}
  keywords={tags.length > 0 ? tags : undefined}
>
  <article class='py-16 md:py-20 min-h-screen'>
    <div class='container-fluid'>
      <!-- Breadcrumb navigation -->
      <nav aria-label='Breadcrumb' class='mb-6'>
        <ol class='flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground'>
          <li>
            <a href='/' class='hover:text-primary transition-colors'>Home</a>
          </li>
          <li aria-hidden='true'>/</li>
          <li>
            <a href='/blog' class='hover:text-primary transition-colors'>Writing</a>
          </li>
          <li aria-hidden='true'>/</li>
          <li class='text-foreground font-medium truncate max-w-[200px] sm:max-w-xs' aria-current='page'>
            {title}
          </li>
        </ol>
      </nav>

      <header class='mb-12'>
        <div class='grid lg:grid-cols-5 gap-8'>
          <div class='lg:col-span-3 space-y-4'>
            <h1
              class='text-3xl md:text-4xl font-semibold first-letter-color'
              transition:name={`blog-title-${Astro.params.slug}`}
            >
              {title}
            </h1>
            <div
              class='flex flex-wrap items-center gap-4 text-muted-foreground text-sm'
            >
              <time datetime={dateCreated.toISOString()}>
                Posted {formattedDate}
              </time>
              {isUpdated && (
                <>
                  <span>•</span>
                  <time datetime={dateModified!.toISOString()} class='italic'>
                    Updated {formattedModifiedDate}
                  </time>
                </>
              )}
              <span>•</span>
              <span>By {author}</span>
              <span>•</span>
              <span>{readingTime} min read</span>
            </div>
            {
              series && (
                <div class='mt-2'>
                  <a
                    href={`/blog?series=${seriesSlug}`}
                    class='inline-flex items-center gap-2 text-sm font-medium text-secondary hover:underline'
                  >
                    <svg
                      xmlns='http://www.w3.org/2000/svg'
                      width='16'
                      height='16'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                    >
                      <path d='M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20' />
                    </svg>
                    Part of series: {series}
                  </a>
                </div>
              )
            }

            {
              coverImage && (
                <Image
                  src={coverImage}
                  width={1000}
                  height={500}
                  alt={title}
                  class='w-full rounded-md shadow-lg mt-6'
                  transition:name={`blog-image-${Astro.params.slug}`}
                />
              )
            }
            <ShareModal
              url={Astro.url.href}
              title={title}
              description={description}
            />
          </div>

          <div class='hidden lg:inline-flex w-full col-span-2'>
            <AuthorSidebar />
          </div>
        </div>
      </header>
      <!-- Main Content Grid -->
      <div
        class:list={[
          'grid gap-8',
          hasSponsors ? 'lg:grid-cols-5' : 'grid-cols-1  mx-auto',
        ]}
      >
        <!-- Blog Content -->
        <div
          class:list={[
            'max-w-none leading-7 [&_h1]:text-4xl [&_h1]:font-bold [&_h1]:mt-8 [&_h1]:mb-4 [&_h2]:text-3xl [&_p]:text-primary retro:[&_p]:text-secondary [&_h2]:font-bold [&_h2]:mt-8 [&_h2]:mb-4 [&_h3]:text-2xl [&_h3]:font-bold [&_h3]:mt-8 [&_h3]:mb-4 [&_h4]:text-xl [&_h4]:font-bold [&_h4]:mt-8 [&_h4]:mb-4 [&_h5]:text-lg [&_h5]:font-bold [&_h5]:mt-8 [&_h5]:mb-4 [&_h6]:text-base [&_h6]:font-bold [&_h6]:mt-8 [&_h6]:mb-4 [&_p]:mb-4 [&_a]:underline  retro:[&_a]:text-primary [&_a]:text-secondary [&_ul]:mb-4 [&_ul]:ml-6 [&_ul]:list-disc [&_ul]:list-outside [&_ol]:mb-4 [&_ol]:ml-6 [&_ol]:list-decimal [&_ol]:list-outside [&_li]:mb-2 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_pre]:p-4 [&_pre]:rounded-md [&_pre]:overflow-x-auto [&_pre]:mb-4  [&_pre_code]:bg-transparent [&_pre_code]:p-0  [&_blockquote]:border-l-4 [&_blockquote]:border-secondary [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:my-4 [&_img]:rounded-md [&_img]:my-6 [&_hr]:w-1/2 [&_hr]:mx-auto  [&_hr]:my-6',
            hasSponsors ? 'lg:col-span-3' : '',
          ]}
        >
          <slot />
        </div>

        {hasSponsors && <SponsorsSidebar sponsors={sponsors} />}
      </div>

      <div class='mt-12 space-y-8'>
        {
          tags && tags.length > 0 && (
            <div>
              <h3 class='text-lg font-semibold mb-3'>Tags</h3>
              <div class='flex flex-wrap gap-2'>
                {tags.map((tag) => (
                  <a
                    href={`/blog?tag=${encodeURIComponent(tag)}`}
                    class='px-3 py-1 text-xs rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors'
                    rel='tag'
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <div class='mt-12 pt-12 border-t border-border'>
        <SocialShare
          url={Astro.url.href}
          title={title}
          description={description}
        />
      </div>

      {
        relatedBlogs.length > 0 && (
          <section class='mt-16 pt-16 border-t border-border'>
            <div class='mb-8'>
              <h2 class='text-2xl md:text-3xl font-semibold mb-2'>
                More from this series
              </h2>
              <p class='text-muted-foreground'>
                Continue reading the {series} series
              </p>
            </div>
            <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'>
              {relatedBlogs.map((blog) => {
                const blogSlug = blog.id.replace(/\.md$/, '');
                return (
                  <ArticleCard
                    title={blog.data.title}
                    description={blog.data.description}
                    dateCreated={blog.data.dateCreated}
                    tags={blog.data.tags}
                    slug={blogSlug}
                    cover_image={blog.data.cover_image}
                  />
                );
              })}
            </div>
          </section>
        )
      }
    </div>
  </article>

  <!-- Newsletter Modal Popup -->
  <NewsletterModal />
</Layout>

<script>
  function setupExternalLinks() {
    const blogContent = document.querySelector('article');
    if (!blogContent) return;

    const links = blogContent.querySelectorAll('a[href^="http"]');
    links.forEach((link) => {
      const href = link.getAttribute('href');

      if (href && !href.includes(window.location.hostname)) {
        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'noopener noreferrer');
      }
    });
  }

  setupExternalLinks();

  document.addEventListener('astro:page-load', () => {
    setupExternalLinks();
  });
</script>
