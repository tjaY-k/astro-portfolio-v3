---
import Layout from '@/layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import { siteConfig } from '@/config';
import { SITE_URL } from '@/lib/env';

const entry = await getEntry('about', 'about-content');

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
const { title, subtitle } = entry.data;

const siteUrl = SITE_URL;
const breadcrumbs = [
  { name: 'Home', item: siteUrl },
  { name: 'About', item: `${siteUrl}/about` },
];

const profilePageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${siteUrl}/about#profilepage`,
  url: `${siteUrl}/about`,
  name: title,
  description: siteConfig.authorDescription,
  dateModified: new Date().toISOString().split('T')[0],
  mainEntity: {
    '@id': `${siteUrl}/#person`,
  },
  breadcrumb: {
    '@id': `${siteUrl}/about#breadcrumb`,
  },
};
---

<Layout
  title='About – Lewis Kori'
  description='Background, principles, and operating philosophy of Lewis Kori. Focused on building durable products, advising institutions, and thinking in systems.'
  ogTitle='About Lewis Kori'
  ogDescription="An entrepreneur's perspective on building, advising, and operating at the intersection of technology and capital."
  breadcrumbs={breadcrumbs}
>
  <script
    type='application/ld+json'
    set:html={JSON.stringify(profilePageSchema)}
  />

  <div class='container-fluid py-16 md:py-20'>
    <div class='mb-12 text-center space-y-4'>
      <div class='inline-block'>
        <span
          class='text-xs uppercase tracking-wider text-primary font-semibold px-4 py-2 rounded-full bg-primary/10 border border-primary/20'
        >
          About
        </span>
      </div>
      <h1
        class='text-3xl md:text-4xl font-semibold text-foreground leading-tight first-letter-color tracking-tight'
      >
        {title}
      </h1>
      {
        subtitle && (
          <p class='text-lg text-muted-foreground font-light max-w-2xl mx-auto'>
            {subtitle}
          </p>
        )
      }
    </div>

    <article
      class='max-w-3xl mx-auto
        [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-foreground
        [&_h2]:mt-12 [&_h2]:mb-4 [&_h2]:scroll-mt-24
        [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-foreground
        [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-base md:[&_p]:text-lg [&_p]:text-foreground/90
        [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:space-y-2 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:ml-6
        [&_li]:text-base md:[&_li]:text-lg [&_li]:text-foreground/90
        [&_li]:leading-relaxed
        [&_strong]:text-secondary [&_strong]:font-semibold
        [&_hr]:my-10 [&_hr]:border-border/50
        [&_a]:text-secondary [&_a]:underline [&_a]:underline-offset-2
        [&_a]:hover:text-primary [&_a]:transition-colors'
    >
      <Content />
    </article>

    <div
      class='mt-20 max-w-3xl mx-auto p-8 md:p-10 rounded-lg bg-linear-to-br from-primary/5 to-secondary/10 border border-border'
    >
      <div class='flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between'>
        <div>
          <h3 class='text-xl font-semibold text-foreground mb-1'>
            Let's Work Together
          </h3>
          <p class='text-sm text-muted-foreground'>
            Interested in building, advising, or collaborating on something meaningful?
          </p>
        </div>
        <div class='flex gap-3 shrink-0'>
          <a
            href='/contact'
            class='px-5 py-2.5 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:bg-primary/90 transition-colors'
          >
            Get in Touch
          </a>
          <a
            href='/advisory'
            class='px-5 py-2.5 bg-secondary/20 text-foreground rounded-md text-sm font-medium hover:bg-secondary/30 transition-colors border border-border'
          >
            Advisory Work
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
